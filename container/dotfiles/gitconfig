# zzzpeak — container ~/.gitconfig (baked into the image; non-secret).
# No identity baked in — run `gh auth login` once in the container (it sets
# user.name/email from your GitHub account) or bind-mount your own ~/.gitconfig
# over this one if you'd rather keep host identity/signing settings.
[init]
	defaultBranch = main
[pull]
	ff = only
[push]
	default = current
	autoSetupRemote = true
[core]
	editor = vim
	excludesfile = ~/.gitignore
[fetch]
	prune = true
[credential]
	# gh installs itself as the HTTPS credential helper once you `gh auth login`
	# (or set GH_TOKEN in the environment) — no SSH key needed in the container.
	helper =
# The repo remote uses a host-side multi-account SSH alias
# (git@amiasloth.github.com:amiasloth/amiasloth.github.io.git) defined in the
# HOST ~/.ssh/config, which isn't mounted into the container. Rewrite it (and
# plain github.com) to HTTPS so the gh credential helper handles push/pull.
# Add more `insteadOf` lines here if you use other host aliases.
[url "https://github.com/"]
	insteadOf = git@github.com:
	insteadOf = ssh://git@github.com/
	insteadOf = git@amiasloth.github.com:
	insteadOf = ssh://git@amiasloth.github.com/
