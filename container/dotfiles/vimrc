filetype plugin indent on
syntax on
set nu
colorscheme ron

" tab settings
set autoindent
set tabstop=2
set expandtab
set shiftwidth=2
set smartindent

" search
set incsearch
set hlsearch
set ignorecase
set smartcase

" quality of life
set hidden
set nobackup
set nowritebackup
set updatetime=300
set signcolumn=number

" hit \pp to toggle paste mode
noremap <leader>pp :set invpaste<cr>

" project-local .vimrc, safely
set exrc
set secure

" ============================================================================
" Solidity navigation over the ingest nav index (see harness/bin/ingest/nav.py)
"   Ctrl-]  : native tags (per-unit src/<label>/sources/tags) — name-based.
"   gd / gr : position-aware go-to-def / find-refs via nav_query — compiler-
"             exact, so two same-named funcs in one unit resolve correctly.
" nav_query lives in the toolkit; override g:nav_query if mounted elsewhere.
" ============================================================================
let g:nav_query = get(g:, 'nav_query', '/toolkit/harness/bin/ingest/nav_query.py')

autocmd BufRead,BufNewFile *.sol setfiletype solidity

" 0-based byte offset of the cursor (vim col/line2byte are byte-based).
function! s:CursorByte() abort
  return line2byte(line('.')) + col('.') - 2
endfunction

function! NavDef() abort
  let l:out = systemlist('python3 ' . shellescape(g:nav_query) . ' jump'
        \ . ' --file ' . shellescape(expand('%:p'))
        \ . ' --offset ' . s:CursorByte())
  if v:shell_error || empty(l:out) || l:out[0] !~# "\t"
    echohl WarningMsg | echo 'nav: no definition (builtin or unresolved)' | echohl NONE
    return
  endif
  let l:p = split(l:out[0], "\t")
  normal! m'
  execute 'edit +' . l:p[1] . ' ' . fnameescape(l:p[0])
endfunction

function! NavRefs() abort
  let l:out = systemlist('python3 ' . shellescape(g:nav_query) . ' usages'
        \ . ' --file ' . shellescape(expand('%:p'))
        \ . ' --offset ' . s:CursorByte())
  if v:shell_error || empty(l:out)
    echohl WarningMsg | echo 'nav: no references' | echohl NONE
    return
  endif
  call setqflist([], ' ', {'lines': l:out, 'title': 'nav: references'})
  copen
endfunction

augroup nav_solidity
  autocmd!
  autocmd FileType solidity setlocal tags=./tags;
  autocmd FileType solidity nnoremap <buffer><silent> gd :call NavDef()<CR>
  autocmd FileType solidity nnoremap <buffer><silent> gr :call NavRefs()<CR>
augroup END
