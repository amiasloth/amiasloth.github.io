# zzzpeak — container .bashrc additions (appended to the base .bashrc at build time)
# Dev container for the chunker (tools/) + previewing the docs/ webapp. Rootless podman.
# You exec into this shell (`podman exec -it zzzpeak bash`), so make it feel like home.

# --- shell behaviour -------------------------------------------------------
set -o vi                         # vi keybindings at the prompt
shopt -s globstar                 # ** recurses
shopt -s histappend
export HISTSIZE=100000 HISTFILESIZE=200000
export HISTCONTROL=ignoreboth

# --- editor ----------------------------------------------------------------
export VISUAL=vim
export EDITOR="$VISUAL"

# --- PATH ------------------------------------------------------------------
# Claude Code native installer drops the binary in ~/.local/bin.
export PATH="$HOME/.local/bin:$PATH"

# --- git-aware prompt ------------------------------------------------------
# green = clean, yellow = ahead of upstream, red = dirty. Tagged [podman] so you always
# know you're in the container shell, not the host.
__set_my_prompt() {
    local RED="\033[0;31m" GREEN="\033[0;32m" YELLOW="\033[0;33m" NOCOLOR="\033[0m"
    local git_modified_color="\[${GREEN}\]"
    if git status 2>/dev/null | grep -q "Your branch is ahead"; then
        git_modified_color="\[${YELLOW}\]"
    fi
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        git_modified_color="\[${RED}\]"
    fi
    local git_branch
    git_branch=$(git branch --show-current 2>/dev/null)
    [ -n "$git_branch" ] && git_branch="$git_modified_color($git_branch)\[${NOCOLOR}\] "
    PS1="\[\033[01;36m\][podman]\[\033[01;32m\] \u \[\033[01;34m\]\w\[\033[00m\] ${git_branch}\[\033[01;32m\]\$ \[\033[00m\]"
}
PROMPT_COMMAND='__set_my_prompt'

# --- git helper ------------------------------------------------------------
mycommit() {
    local msg="$1"
    git add -A
    git commit -m "$msg"
    git push
}

# --- docs preview ------------------------------------------------------------
# Serves docs/ (the GitHub Pages webapp) on the port published by run.sh.
# localhost counts as a secure context, so mic capture + the service worker
# still work even without HTTPS.
serve-docs() {
    local port="${1:-8080}"
    (cd /project/docs && python3 -m http.server "$port")
}

# --- convenience aliases ---------------------------------------------------
alias ll='ls -alF'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
alias build-data='bash /project/tools/build_data.sh'
