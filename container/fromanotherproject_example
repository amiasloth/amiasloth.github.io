# syntax=docker/dockerfile:1.6
# ============================================================================
# Harness — the brain. Claude Code + Mistral Vibe + JetBrains Junie CLIs +
# git/gh + vim/tmux + ssh client. Three agents, ONE image: each is a separate
# binary on ~/.local/bin, with a separate config dir (~/.claude · ~/.vibe ·
# ~/.junie), a separate project dir (.claude · .vibe · .junie), and a separate
# OPTIONAL auth env var — they only ever READ the shared AGENTS.md, so there is
# no conflict. See AI-for-audit design discussion 15.
# LEAN by design: file & project management only. NO heavy audit tools
# (foundry/slither/semgrep/solc) and NO podman socket — those live in the sandbox.
# NB: with agents run in bypass/auto-approve mode, this lean image (no forge/
# slither/solc) IS the real safety boundary — keep it lean.
# Runs as service user uid=1000 so bind-mounted files stay host-owned under
# Quadlet UserNS=keep-id. You attach interactively: `podman exec -it harness-<t> claude`
#   (swap `claude` for `vibe` or `junie` to drive the same repo with another agent).
# (or `... bash` — hence the baked-in dotfiles).
#
# BUILD CONTEXT = host/  (so both dotfiles/ and dockerfiles/ are reachable):
#   podman build -t audit-harness:v0 -f host/dockerfiles/Containerfile.harness host
# ============================================================================
FROM debian:trixie-slim

ARG USERNAME=audit
ARG USER_UID=1000
# Pin Claude Code by passing --build-arg CLAUDE_VERSION=<x.y.z>; empty = latest stable.
ARG CLAUDE_VERSION=""
# Pin Mistral Vibe by passing --build-arg VIBE_VERSION=<x.y.z>; empty = latest.
# (Junie's installer tracks its own release channel; no version pin exposed yet.)
ARG VIBE_VERSION=""

# --- system packages (root) ------------------------------------------------
# git/gh: project + repo control (the harness drives git & gh so project-kickoff
# can be automated). vim/tmux/ripgrep/jq/tree/less: for exec'ing in.
# openssh-client: the `sbx` SSH seam to the sandbox.
# python3: the source-ingestion pipeline (harness/bin/ingest/) — STDLIB ONLY, no
#   pip, so plain python3 is enough. Fetch (Sourcify/Etherscan over HTTP) runs
#   here; compile hops to the sandbox via `sbx`. See discussion/13.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg \
        git openssh-client \
        vim tmux \
        ripgrep jq tree less bash-completion procps \
        python3 \
        unzip xz-utils \
    && rm -rf /var/lib/apt/lists/*
# unzip: JetBrains Junie ships its release as a .zip the installer extracts.
# xz-utils: uv (bootstrapped by the Vibe installer) unpacks xz-compressed artifacts.

# --- GitHub CLI (official apt repo, keyring-verified) ----------------------
# Community-distributed gh builds are broken against deprecated GitHub APIs; use the
# official repo (https://github.com/cli/cli/blob/trunk/docs/install_linux.md).
RUN install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# --- service user = host uid 1000 (keep-id maps it back to the host user) --
RUN useradd -m -u ${USER_UID} -s /bin/bash ${USERNAME}
USER ${USERNAME}
ENV HOME="/home/${USERNAME}"
WORKDIR /project

# --- Claude Code (native installer; npm is deprecated as of Jan 2026) ------
# Installs the standalone binary to ~/.local/bin/claude and auto-updates in the
# background. Token is injected at runtime via the CLAUDE_CODE_OAUTH_TOKEN secret.
RUN if [ -n "${CLAUDE_VERSION}" ]; then \
        curl -fsSL https://claude.ai/install.sh | bash -s -- "${CLAUDE_VERSION}"; \
    else \
        curl -fsSL https://claude.ai/install.sh | bash; \
    fi

# Non-login PATH (podman exec doesn't source login files): claude + harness scripts.
#  - /toolkit/harness/bin   — AGENT tools the CLI runs mid-audit: sbx, memory.sh,
#                             new-poc.sh, export-poc.sh, ingest/.
#  - /toolkit/harness/setup — OPERATOR setup you run by hand before the CLI: kickoff.sh.
# Both are on PATH so either resolves by bare name; the folder split marks intent.
ENV PATH="${HOME}/.local/bin:${HOME}/.junie/bin:/toolkit/harness/bin:/toolkit/harness/setup:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# --- Mistral Vibe (official installer; bootstraps `uv`, then `uv tool install`) --
# The one-liner installs `uv` if missing and installs/upgrades `mistral-vibe`,
# exposing `vibe` (+ `vibe-acp`) on ~/.local/bin. Vibe self-updates at runtime.
# Auth is the OPTIONAL MISTRAL_API_KEY env secret (see entrypoint) — NOT baked in.
# A VIBE_VERSION pin, if given, is force-installed over the latest via uv.
RUN curl -LsSf https://mistral.ai/vibe/install.sh | bash \
    && if [ -n "${VIBE_VERSION}" ]; then \
         PATH="${HOME}/.local/bin:${PATH}" uv tool install "mistral-vibe==${VIBE_VERSION}" --force; \
       fi

# --- JetBrains Junie CLI (official installer) -------------------------------
# LLM-agnostic agent; self-updating. Auth is OPTIONAL at runtime: JUNIE_API_KEY
# (usage-based) or a JetBrains-account/BYOK token — nothing baked in here.
# The installer may drop the binary in ~/.junie/bin; symlink it into ~/.local/bin
# (already on PATH) so `junie` resolves by bare name regardless of install dir.
RUN curl -fsSL https://junie.jetbrains.com/install.sh | bash \
    && if [ -x "${HOME}/.junie/bin/junie" ] && [ ! -e "${HOME}/.local/bin/junie" ]; then \
         ln -sf "${HOME}/.junie/bin/junie" "${HOME}/.local/bin/junie"; \
       fi

# --- dotfiles (so exec'd shells feel like your box: set -o vi, git prompt, vim, tmux)
COPY --chown=${USER_UID}:${USER_UID} dotfiles/bashrc    ${HOME}/.bashrc.audit
COPY --chown=${USER_UID}:${USER_UID} dotfiles/vimrc     ${HOME}/.vimrc
COPY --chown=${USER_UID}:${USER_UID} dotfiles/tmux.conf ${HOME}/.tmux.conf
COPY --chown=${USER_UID}:${USER_UID} dotfiles/gitconfig ${HOME}/.gitconfig
COPY --chown=${USER_UID}:${USER_UID} dotfiles/gitignore ${HOME}/.gitignore
RUN cat ${HOME}/.bashrc.audit >> ${HOME}/.bashrc && rm ${HOME}/.bashrc.audit

# vim: fugitive (git inside vim) — the harness is a git-driving box.
RUN mkdir -p "${HOME}/.vim/pack/tpope/start" \
    && git clone --depth 1 https://tpope.io/vim/fugitive.git \
        "${HOME}/.vim/pack/tpope/start/fugitive" \
    && vim -u NONE -c "helptags ${HOME}/.vim/pack/tpope/start/fugitive/doc" -c q


# --- verify all three agent CLIs resolve (fail the build early if not) -------
# Bare-name resolution proves each landed on PATH; no auth needed for this.
RUN for b in claude vibe junie; do \
        command -v "$b" >/dev/null || { echo "BUILD ERROR: '$b' not on PATH after install" >&2; exit 1; }; \
        echo "ok: $b -> $(command -v "$b")"; \
    done

# Entrypoint is a keepalive that wires git/gh auth — NOT `claude` itself.
COPY --chown=${USER_UID}:${USER_UID} dockerfiles/entrypoint-harness.sh /usr/local/bin/entrypoint-harness.sh
RUN chmod +x /usr/local/bin/entrypoint-harness.sh
ENTRYPOINT ["/usr/local/bin/entrypoint-harness.sh"]

# --- provenance labels (LAST so they don't bust cache on the layers above) --
# Populated by build-images.sh from the audit-toolkit git repo. The repo SHA
# identifies the *recipe*; the image content digest (podman images --digests) is
# the true identity of the built result. See discussion/06 + ARCHITECTURE §10.
#   inspect:  podman inspect audit-harness:v0 \
#     --format '{{index .Labels "org.opencontainers.image.revision"}} {{index .Labels "org.opencontainers.image.created"}}'
ARG GIT_REVISION=""
ARG GIT_DIRTY=""
ARG BUILD_DATE=""
ARG IMAGE_SOURCE=""
ARG IMAGE_VERSION="v0"
LABEL org.opencontainers.image.title="audit-harness" \
      org.opencontainers.image.version="${IMAGE_VERSION}" \
      org.opencontainers.image.revision="${GIT_REVISION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.source="${IMAGE_SOURCE}" \
      dev.audit-toolkit.git-dirty="${GIT_DIRTY}"
