# Copy to container/secret.env and fill in (that file is gitignored, this
# example is not). container/run.sh sources it and forwards these into the
# container if set. Leave a line blank/absent to skip it.

# Claude Code auth token (lets `claude` inside the container run non-interactively).
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub token, used by `gh`/git over HTTPS (see container/dotfiles/gitconfig
# for why HTTPS instead of your host's SSH alias). A `gh auth login` inside
# the container works too and doesn't need this.
GH_TOKEN=
